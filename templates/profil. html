{% extends "layout.html" %}
{% block content %}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm p-4">
            <h2 class="text-center mb-4">Paramètres du Profil</h2>
            <form method="POST">
                <div class="mb-3">
                    <label class="form-label">Nom de votre Entreprise</label>
                    <input type="text" name="nom_entreprise" class="form-control" value="{{ profil.nom_entreprise }}" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Nom du Gérant</label>
                    <input type="text" name="gerant" class="form-control" value="{{ profil.gerant }}" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Téléphone (WhatsApp)</label>
                    <input type="text" name="telephone" class="form-control" value="{{ profil.telephone }}" required>
                </div>
                <button type="submit" class="btn btn-primary w-100">Enregistrer les modifications</button>
            </form>
            <div class="mt-3 text-center">
                <a href="/" class="text-decoration-none text-muted">← Retour à l'accueil</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}

